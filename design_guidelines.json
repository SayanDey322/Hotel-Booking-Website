        "border": "#E7E5E4"
      },
      "feedback": {
        "success": "#059669",
        "error": "#DC2626",
        "warning": "#D97706"
      }
    },
    "typography": {
      "headings": {
        "family": "Playfair Display, serif",
        "weights": ["400", "600", "700"],
        "usage": "All Section Headers, Hero Titles, Card Titles"
      },
      "body": {
        "family": "Manrope, sans-serif",
        "weights": ["400", "500", "600"],
        "usage": "Paragraphs, UI Elements, Inputs, Buttons"
      },
      "mono": {
        "family": "JetBrains Mono, monospace",
        "usage": "Booking IDs, Transaction Codes"
      }
    },
    "spacing": {
      "scale": "Generous (2x standard)",
      "container_padding": "p-6 md:p-12 lg:p-20",
      "section_gap": "gap-16 md:gap-24",
      "element_gap": "gap-4 md:gap-8"
    },
    "radius": {
      "default": "rounded-sm",
      "buttons": "rounded-none",
      "cards": "rounded-md"
    }
  },
  "layout_strategies": {
    "marketing_pages": {
      "grid_type": "Mode A: The Tetris Grid",
      "rules": [
        "Use grid-cols-12 for desktop",
        "Never center text by default (unless for specific editorial balance)",
        "Use overlapping elements (z-index) to break the grid",
        "Hero sections must use full-width imagery with overlay text"
      ]
    },
    "dashboard_pages": {
      "grid_type": "Mode B: High Density Grid",
      "rules": [
        "Use grid-cols-4 for metrics",
        "Cards must stretch to fill height (h-full)",
        "Use 'Glassmorphism' for sticky headers and floating actions",
        "Dense spacing (p-4) for data tables"
      ]
    }
  },
  "component_rules": {
    "buttons": {
      "primary": "bg-primary text-white hover:bg-primary/90 rounded-none px-8 py-6 text-lg font-serif tracking-wide transition-all duration-300",
      "secondary": "border border-primary text-primary hover:bg-primary/5 rounded-none px-8 py-6 text-lg font-serif tracking-wide",
      "ghost": "text-primary hover:text-accent hover:bg-transparent font-medium"
    },
    "cards": {
      "hotel_card": "group relative overflow-hidden rounded-md border-none shadow-lg hover:shadow-xl transition-all duration-500",
      "feature_card": "bg-white/50 backdrop-blur-sm border border-stone-200 p-8 hover:border-primary/20 transition-colors"
    },
    "inputs": {
      "style": "bg-white border-stone-200 focus:border-primary focus:ring-primary/20 rounded-sm h-12"
    },
    "navigation": {
      "style": "fixed top-0 w-full z-50 bg-white/80 backdrop-blur-md border-b border-stone-100 transition-all duration-300"
    }
  },
